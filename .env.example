# Example environment file for degree-guidance.
# Copy to .env and fill in real values. NEVER commit the real .env.
# All keys below are REQUIRED unless marked optional.

# --- Database ---
# Async DSN (asyncpg) used by the FastAPI app and the ingestion jobs.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
# Sync DSN (psycopg2) used by Alembic migrations only.
DATABASE_URL_SYNC=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

# --- Runtime ---
# Deployment environment: local | staging | production
ENVIRONMENT=local
# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Import root so `core`/`apps` resolve. Keep as "." at the project root.
PYTHONPATH=.

# --- Auth / JWT ---
# HS256 signing key for access tokens. Generate locally, keep secret, never commit.
# e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
JWT_SECRET_KEY=
# JWT signing algorithm. HS256 unless you have a reason to change it.
JWT_ALGORITHM=HS256
# Access-token lifetime in minutes.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Redis / background jobs (Arq) ---
# Redis DSN used as the Arq broker (PDF-extraction jobs) and cache.
REDIS_URL=redis://localhost:6379/0
