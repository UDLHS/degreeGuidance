# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Backup / temp files (never commit)
*.bak
*.tmp
*.orig
*.rej

# Data — never commit raw handbooks, OCR outputs, or uploaded files
data/raw/
data/output/
data/uploads/
data/ingestion_work/
images/
*.pdf

# Logs
*.log
logs/

# Node (for later, web/ folder)
node_modules/
.next/
out/

# Secrets
*.pem
*.key

# Windows download-marker ADS files (WSL shows them as real files;
# the separator is a Unicode colon U+F03A, so match the suffix broadly)
*Zone.Identifier

# Claude Code session-local state
.claude/
